# ── Required ──────────────────────────────────────────────────
INBOXED_DOMAIN=mail.example.com
INBOXED_BASE_URL=http://localhost:3100
DASHBOARD_URL=http://localhost:5173
SECRET_KEY_BASE=generate-with-bin-rails-secret
POSTGRES_PASSWORD=changeme

# ── Setup & Auth ─────────────────────────────────────────────
# One-time token for creating the first admin account via /setup.
# After setup completes, this token is no longer used.
INBOXED_SETUP_TOKEN=changeme

# Registration: open (anyone), invite_only (token required), closed (admin only)
REGISTRATION_MODE=closed

# Trial duration for new orgs when REGISTRATION_MODE=open (0 = permanent)
TRIAL_DURATION_DAYS=7

# ── GitHub OAuth (optional) ──────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Outbound SMTP — system emails (optional) ─────────────────
# Required for email verification, password reset, and invitations.
# Without this, users are auto-verified and password reset is unavailable.
# OUTBOUND_SMTP_HOST=smtp.resend.com
# OUTBOUND_FROM_EMAIL=noreply@yourdomain.com

# ── SMTP Server — inbound email catching ─────────────────────
# SMTP_HOST=0.0.0.0
# SMTP_PORTS=2525
# SMTP_MAX_CONNECTIONS=4
# SMTP_TLS_CERT=
# SMTP_TLS_KEY=

# ── Port overrides (docker-compose) ──────────────────────────
INBOXED_WEB_PORT=3200
INBOXED_API_PORT=3100
INBOXED_MCP_PORT=3201
INBOXED_SMTP_PORT=1587
INBOXED_SMTPS_PORT=1465

# ── Email & Storage ──────────────────────────────────────────
EMAIL_TTL_HOURS=168
INBOXED_MAX_EMAILS_PER_PROJECT=10000
INBOXED_MAX_MESSAGE_SIZE_MB=25

# ── MCP Server ───────────────────────────────────────────────
INBOXED_MCP_KEY=

# ── Feature flags (true/false, all default to true) ──────────
# INBOXED_FEATURE_HOOKS=true
# INBOXED_FEATURE_FORMS=true
# INBOXED_FEATURE_HEARTBEATS=true

# ── Rate limits (requests per period, see rack_attack.rb) ────
# RATE_LIMIT_API=300
# RATE_LIMIT_ADMIN=60
# RATE_LIMIT_HOOK=120
# RATE_LIMIT_HOOK_GLOBAL=1000
# RATE_LIMIT_AUTH=5

# ── Infrastructure ───────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# RAILS_MAX_THREADS=5
# RAILS_LOG_LEVEL=info
# JOB_CONCURRENCY=5
