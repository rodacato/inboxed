# ── Required ──────────────────────────────────────────────────
INBOXED_DOMAIN=mail.notdefined.dev
INBOXED_ADMIN_TOKEN=changeme
SECRET_KEY_BASE=generate-with-bin-rails-secret
POSTGRES_PASSWORD=changeme

# ── Optional — port overrides (defaults avoid collisions) ────
INBOXED_WEB_PORT=3200
INBOXED_MCP_PORT=3201
INBOXED_SMTP_PORT=1587
INBOXED_SMTPS_PORT=1465

# ── Optional — tuning ────────────────────────────────────────
INBOXED_DEFAULT_TTL_HOURS=168
INBOXED_MAX_EMAILS_PER_PROJECT=10000
INBOXED_MAX_MESSAGE_SIZE_MB=25
INBOXED_MCP_KEY=
