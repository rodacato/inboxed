# ╔════════════════════════════════════════════════════════════════╗
# ║  Inboxed — Environment Configuration                         ║
# ║  Copy to .env and edit, or run bin/setup to generate it.     ║
# ╚════════════════════════════════════════════════════════════════╝


# ── Required ──────────────────────────────────────────────────
# These MUST be set before starting. bin/setup generates them automatically.

# Domain used for the SMTP server. Emails sent to *@this-domain get caught.
INBOXED_DOMAIN=mail.example.com

# Full URL where the Rails API is accessible (used for CORS, MCP, links).
INBOXED_BASE_URL=http://localhost:3100

# Full URL where the Svelte dashboard is accessible.
DASHBOARD_URL=http://localhost:5173

# Rails secret key. Generate with: openssl rand -hex 64
SECRET_KEY_BASE=generate-with-bin-rails-secret

# PostgreSQL password. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=changeme


# ── Setup & Auth ─────────────────────────────────────────────

# One-time token for creating the first admin account via /setup.
# Open https://your-dashboard/setup and enter this token to create the admin.
# After setup completes, this token is no longer used.
INBOXED_SETUP_TOKEN=changeme

# Who can create accounts:
#   open        — anyone can register (good for shared team instances)
#   invite_only — users need an invitation link from an admin
#   closed      — only admins can create accounts (most secure)
REGISTRATION_MODE=closed

# Auto-expire new organizations after N days. Only applies when REGISTRATION_MODE=open.
# Set to 0 for permanent accounts (no trial).
TRIAL_DURATION_DAYS=7


# ── GitHub OAuth (optional) ──────────────────────────────────
# Enable "Sign in with GitHub" on the login page.
# Create an OAuth App at https://github.com/settings/developers
# Set callback URL to: ${DASHBOARD_URL}/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=


# ── Outbound SMTP — system emails (optional) ─────────────────
# Used for: email verification, password reset, and invitation emails.
# Without this, users are auto-verified on signup and password reset is unavailable.
# Works with any SMTP provider: Resend, Postmark, SendGrid, SES, etc.
# OUTBOUND_SMTP_HOST=smtp.resend.com
# OUTBOUND_FROM_EMAIL=noreply@yourdomain.com


# ── SMTP Server — inbound email catching ─────────────────────
# Settings for the built-in SMTP server that catches emails from your app.

# Interface to bind. 0.0.0.0 = all interfaces (default).
# SMTP_HOST=0.0.0.0

# SMTP port. Standard ports: 25 (internet delivery), 587 (submission), 2525 (non-privileged).
# SMTP_PORTS=2525

# Max simultaneous SMTP connections.
# SMTP_MAX_CONNECTIONS=4

# TLS certificate and key paths for SMTPS (port 465). Leave empty for no TLS.
# SMTP_TLS_CERT=
# SMTP_TLS_KEY=

# Max recipients per email (prevents abuse).
# SMTP_MAX_RECIPIENTS=100

# Max emails per minute from a single sender IP.
# SMTP_RATE_LIMIT_PER_MIN=60


# ── Port overrides (docker-compose) ──────────────────────────
# Change these if the default ports conflict with other services on your machine.

INBOXED_WEB_PORT=3200       # Dashboard (Svelte)
INBOXED_API_PORT=3100       # API (Rails)
INBOXED_MCP_PORT=3201       # MCP server (Node.js)
INBOXED_SMTP_PORT=1587      # SMTP submission
INBOXED_SMTPS_PORT=1465     # SMTPS (encrypted)


# ── Email & Storage ──────────────────────────────────────────

# Auto-delete emails older than N hours. 168 = 7 days. Set to 0 to keep forever.
EMAIL_TTL_HOURS=168

# Max emails per project before oldest are pruned.
INBOXED_MAX_EMAILS_PER_PROJECT=10000

# Max email size in megabytes. Emails larger than this are rejected by the SMTP server.
INBOXED_MAX_MESSAGE_SIZE_MB=3


# ── MCP Server ───────────────────────────────────────────────
# API key the MCP server uses to authenticate with the Rails API.
# Generate with: openssl rand -hex 32
# This is NOT a user-facing key — it's an internal service credential.
INBOXED_MCP_KEY=


# ── Inbound Email — Cloudflare Email Routing (optional) ──────
# Enable receiving real emails from the internet via Cloudflare Email Workers.
# See the Self-Host Guide → Production → Inbound Email section for setup steps.
# The shared secret must match the one configured in the Cloudflare Worker.
# INBOUND_WEBHOOK_SECRET=generate-a-secure-random-token


# ── Feature Flags ────────────────────────────────────────────
# Toggle features on or off. All default to true except inbound email.
# Set to false to hide the feature from the dashboard and disable its API endpoints.

# HTTP Hooks — catch webhooks from external services (Stripe, GitHub, etc.)
# INBOXED_FEATURE_HOOKS=true

# Form Endpoints — catch HTML form submissions via POST
# INBOXED_FEATURE_FORMS=true

# Heartbeat Endpoints — monitor periodic HTTP pings (cron jobs, health checks)
# INBOXED_FEATURE_HEARTBEATS=true

# Inbound Email — receive real emails from the internet (requires Cloudflare Worker or MX setup)
# Disabled by default because it needs external infrastructure to work.
# INBOXED_FEATURE_INBOUND_EMAIL=false


# ── Rate Limits ──────────────────────────────────────────────
# Requests per period per IP. See config/initializers/rack_attack.rb for details.

# RATE_LIMIT_API=300            # API requests per minute (authenticated)
# RATE_LIMIT_ADMIN=60           # Admin panel requests per minute
# RATE_LIMIT_HOOK=120           # Webhook/form/heartbeat requests per minute per endpoint
# RATE_LIMIT_HOOK_GLOBAL=1000   # Total hook requests per minute across all endpoints
# RATE_LIMIT_AUTH=5             # Login/register attempts per minute per IP


# ── Infrastructure ───────────────────────────────────────────
# Usually you don't need to change these. The docker-compose.yml sets them automatically.

# REDIS_URL=redis://localhost:6379/0      # Redis for ActionCable and caching
# RAILS_MAX_THREADS=5                     # Puma threads per worker
# RAILS_LOG_LEVEL=info                    # debug, info, warn, error
# JOB_CONCURRENCY=5                       # Solid Queue background job workers
