:80 {
    handle /api/* {
        reverse_proxy inboxed-web:3000
    }

    handle /admin/* {
        reverse_proxy inboxed-web:3000
    }

    handle /auth/* {
        reverse_proxy inboxed-web:3000
    }

    @setup_api {
        path /setup
        method POST
    }
    handle @setup_api {
        reverse_proxy inboxed-web:3000
    }

    handle /cable {
        reverse_proxy inboxed-web:3000
    }

    handle /up {
        reverse_proxy inboxed-web:3000
    }

    handle /hook/* {
        reverse_proxy inboxed-web:3000
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
