#!/usr/bin/env bash
set -euo pipefail

# ── Colors ────────────────────────────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

print_banner() {
  echo ""
  echo -e "  ${GREEN}${BOLD}[@] Inboxed Setup${NC}"
  echo -e "  ${DIM}─────────────────${NC}"
  echo ""
}

check_command() {
  local cmd="$1"
  local message="$2"
  if ! command -v "$cmd" &>/dev/null; then
    echo -e "  ${RED}✗${NC} $cmd not found"
    echo -e "    ${DIM}$message${NC}"
    exit 1
  fi
}

check_docker_compose() {
  if docker compose version &>/dev/null; then
    return 0
  fi
  echo -e "  ${RED}✗${NC} Docker Compose v2 not found"
  echo -e "    ${DIM}Install: https://docs.docker.com/compose/install/${NC}"
  exit 1
}

warn_port() {
  local port="$1"
  local name="$2"
  if command -v ss &>/dev/null; then
    if ss -tlnp 2>/dev/null | grep -q ":${port} "; then
      echo -e "  ${YELLOW}!${NC} Port $port ($name) is already in use"
    fi
  elif command -v lsof &>/dev/null; then
    if lsof -i ":${port}" &>/dev/null; then
      echo -e "  ${YELLOW}!${NC} Port $port ($name) is already in use"
    fi
  fi
}

# ── Main ──────────────────────────────────────────────────────

print_banner

# Warn if running as root
if [ "$(id -u)" -eq 0 ]; then
  echo -e "  ${YELLOW}! Running as root is not recommended${NC}"
  echo ""
fi

# Prerequisites
echo -e "  Checking prerequisites..."
check_command "docker" "Install: https://docs.docker.com/get-docker/"
DOCKER_VERSION=$(docker --version 2>/dev/null | head -1)
echo -e "  ${GREEN}✓${NC} $DOCKER_VERSION"

check_docker_compose
COMPOSE_VERSION=$(docker compose version 2>/dev/null | head -1)
echo -e "  ${GREEN}✓${NC} $COMPOSE_VERSION"

check_command "openssl" "openssl is required for secret generation."
echo ""

# Check for existing .env
ENV_FILE="$(cd "$(dirname "$0")/.." && pwd)/.env"
ENV_EXAMPLE="$(cd "$(dirname "$0")/.." && pwd)/.env.example"

if [ -f "$ENV_FILE" ]; then
  echo -e "  ${YELLOW}!${NC} .env already exists"
  read -p "  Overwrite? [y/N]: " OVERWRITE
  if [[ ! "$OVERWRITE" =~ ^[Yy]$ ]]; then
    echo -e "  ${DIM}Keeping existing .env${NC}"
    echo ""
    echo -e "  Next steps:"
    echo -e "    ${BOLD}docker compose up -d${NC}"
    echo ""
    exit 0
  fi
  echo ""
fi

# Interactive configuration
echo -e "  ${BOLD}Configuration:${NC}"
read -p "  Domain [localhost]: " INBOXED_DOMAIN
INBOXED_DOMAIN="${INBOXED_DOMAIN:-localhost}"

read -p "  Dashboard port [80]: " DASHBOARD_PORT
DASHBOARD_PORT="${DASHBOARD_PORT:-80}"

read -p "  SMTP port [587]: " SMTP_PORT
SMTP_PORT="${SMTP_PORT:-587}"

echo ""

# Check port availability
warn_port "$DASHBOARD_PORT" "dashboard"
warn_port "$SMTP_PORT" "SMTP"
warn_port "5432" "PostgreSQL"

# Generate secrets
echo -e "  Generating secrets..."
SECRET_KEY_BASE=$(openssl rand -hex 64)
echo -e "  ${GREEN}✓${NC} SECRET_KEY_BASE ${DIM}(64 bytes)${NC}"

INBOXED_ADMIN_TOKEN=$(openssl rand -hex 32)
echo -e "  ${GREEN}✓${NC} INBOXED_ADMIN_TOKEN ${DIM}(32 bytes)${NC}"

POSTGRES_PASSWORD=$(openssl rand -hex 32)
echo -e "  ${GREEN}✓${NC} POSTGRES_PASSWORD ${DIM}(32 bytes)${NC}"

INBOXED_MCP_KEY=$(openssl rand -hex 32)
echo -e "  ${GREEN}✓${NC} INBOXED_MCP_KEY ${DIM}(32 bytes)${NC}"

echo ""

# Write .env
cat > "$ENV_FILE" <<EOF
# ── Generated by bin/setup on $(date -u +"%Y-%m-%dT%H:%M:%SZ") ──

# ── Required ──────────────────────────────────────────────────
INBOXED_DOMAIN=${INBOXED_DOMAIN}
INBOXED_ADMIN_TOKEN=${INBOXED_ADMIN_TOKEN}
SECRET_KEY_BASE=${SECRET_KEY_BASE}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# ── Ports ─────────────────────────────────────────────────────
INBOXED_WEB_PORT=${DASHBOARD_PORT}
INBOXED_SMTP_PORT=${SMTP_PORT}
INBOXED_MCP_PORT=3001

# ── MCP ───────────────────────────────────────────────────────
INBOXED_MCP_KEY=${INBOXED_MCP_KEY}

# ── Optional — tuning ────────────────────────────────────────
INBOXED_DEFAULT_TTL_HOURS=168
INBOXED_MAX_EMAILS_PER_PROJECT=10000
INBOXED_MAX_MESSAGE_SIZE_MB=25
EOF

chmod 600 "$ENV_FILE"
echo -e "  ${GREEN}✓${NC} .env written ${DIM}(chmod 600)${NC}"
echo ""

# Next steps
echo -e "  ${BOLD}Next steps:${NC}"
echo -e "    ${BOLD}docker compose up -d${NC}"
if [ "$INBOXED_DOMAIN" = "localhost" ]; then
  echo -e "    open ${BOLD}http://localhost:${DASHBOARD_PORT}${NC}"
else
  echo -e "    open ${BOLD}http://${INBOXED_DOMAIN}:${DASHBOARD_PORT}${NC}"
fi
echo ""
echo -e "  Send a test email:"
echo -e "    ${DIM}swaks --to test@${INBOXED_DOMAIN} --server localhost:${SMTP_PORT}${NC}"
echo ""
